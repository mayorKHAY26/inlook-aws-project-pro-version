{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDangerousActions",
      "Effect": "Deny",
      "Action": [
        "organizations:*",
        "account:*",
        "billing:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowInfrastructureManagement",
      "Effect": "Allow",
      "Action": [
        "ec2:*",
        "ecs:*",
        "ecr:*",
        "rds:*",
        "cloudwatch:*",
        "logs:*",
        "elasticloadbalancing:*",
        "s3:*",
        "iam:*"
      ],
      "Resource": "*"
    }
  ]
}